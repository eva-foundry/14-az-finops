.create-merge table raw_costs (Date:datetime, SubscriptionId:string, SubscriptionName:string, ResourceGroup:string, ResourceId:string, ResourceName:string, ResourceLocation:string, ResourceType:string, MeterCategory:string, MeterSubCategory:string, MeterId:string, MeterName:string, Quantity:real, EffectivePrice:real, CostInBillingCurrency:real, BillingCurrency:string, Tags:dynamic, ConsumedService:string, CostCenter:string, IngestionTime:datetime)
